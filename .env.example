# MYTHRIX.AI environment configuration
# Copy this file to `.env` and fill in your real keys. Never commit `.env`.

# ---------- Core backend ----------
MYTHRIX_API_BASE_URL=https://api.mythrix.ai/v1
MYTHRIX_WS_BASE_URL=wss://ws.mythrix.ai/v1
MYTHRIX_ENV=development

# ---------- FREE AI provider ----------
# Google Gemini — FREE tier (1,500 requests/day), no credit card needed.
# Get a key in 60 seconds: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---------- Paid AI providers (optional, leave empty if you don't pay yet) ----------
# Anthropic Claude — pay-per-token (~$3/M input tokens). Separate from Claude Pro chat.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI — pay-per-token. Get one at https://platform.openai.com
OPENAI_API_KEY=
# Stability — pay-per-image. https://platform.stability.ai
STABILITY_API_KEY=
# Runway Gen-3/4 video. https://dev.runwayml.com
RUNWAY_API_KEY=
# ElevenLabs voice. https://elevenlabs.io
ELEVENLABS_API_KEY=

# Routing preferences — defaults to free Gemini.
AI_DEFAULT_TEXT_PROVIDER=gemini
AI_DEFAULT_IMAGE_PROVIDER=stability
AI_DEFAULT_VIDEO_PROVIDER=runway

# ---------- Ad platforms (V2 — leave empty for now) ----------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_ADS_APP_ID=
META_ADS_APP_SECRET=
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
LINKEDIN_ADS_CLIENT_ID=
LINKEDIN_ADS_CLIENT_SECRET=

# ---------- Social platforms ----------
INSTAGRAM_APP_ID=
FACEBOOK_APP_ID=
TWITTER_API_KEY=
LINKEDIN_CLIENT_ID=
TIKTOK_CLIENT_KEY=
YOUTUBE_API_KEY=
PINTEREST_APP_ID=

# ---------- Stripe billing ----------
# Publishable key starts with pk_ — safe to ship to client
STRIPE_PUBLISHABLE_KEY=
# Stripe Merchant ID for Apple Pay (optional)
STRIPE_MERCHANT_ID=

# ---------- Telemetry ----------
SENTRY_DSN=
