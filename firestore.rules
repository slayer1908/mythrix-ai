rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile document.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // Workspace members can read; only owners + admins can write.
    match /workspaces/{workspaceId} {
      function isMember() {
        return request.auth != null
          && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      }
      function isAdmin() {
        return isMember()
          && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
      }

      allow read: if isMember();
      allow update, delete: if isAdmin();
      allow create: if request.auth != null;

      match /{collection}/{docId=**} {
        allow read: if isMember();
        allow write: if isMember();
      }
    }
  }
}
